{
  "expo": {
    "name": "shiacast",
    "slug": "shiacast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shiacast",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.hadi-ea.shiacast",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select images.",
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleLocalizations": [
          "de",
          "en",
          "ar"
        ],
        "CFBundleDevelopmentRegion": "de",
        "NSUserNotificationsUsageDescription": "Wir senden Push-Benachrichtigungen"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hadi_ea.shiacast",
      "permissions": []
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      "expo-image",
      "expo-asset",
      "expo-localization",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/shiacast"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "17addcb3-1e38-464c-a41d-acadb2a72696"
      },
      "supabaseUrl": "https://thqtmzvrjdodgorexjcj.supabase.co",
      "supabasePublishableKey": "sb_publishable_6cc9AgTAoAY9kXSypBrwfw_KGyuSozE"
    },
    "owner": "hadi_ea"
  }
}
